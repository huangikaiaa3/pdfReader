APP_NAME=pdfReader
ENVIRONMENT=production

# Optional override if you ever point the app at an external database again.
APP_DATABASE_URL=

# Local Compose stack on EC2.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/pdfreader
REDIS_URL=redis://redis:6379/0

# Vercel frontend origin.
CORS_ALLOWED_ORIGINS=https://pdf-reader-virid.vercel.app

AUTH_SESSION_TTL_DAYS=30
STORAGE_BACKEND=local
STORAGE_ROOT=/app/storage
STORAGE_BUCKET=
STORAGE_KEY_PREFIX=documents
LOG_LEVEL=INFO

MAX_UPLOAD_SIZE_BYTES=10485760
MAX_PDF_PAGES=100
MAX_SESSION_QUESTION_CHARS=4000
SESSION_INACTIVITY_TIMEOUT_MINUTES=60
SESSION_CLEANUP_INTERVAL_SECONDS=60

GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_OUTPUT_DIMENSIONALITY=768
GENERATION_MODEL=gemini-2.5-flash
ANSWER_CITATION_COUNT=2
RETRIEVAL_WEAK_MATCH_MAX_DISTANCE=0.4

INGESTION_QUEUE_NAME=ingestion_jobs
INGESTION_EVENT_CHANNEL=ingestion_events
INGESTION_MAX_ATTEMPTS=3

# Used by the postgres container in docker-compose.prod.yml.
POSTGRES_PASSWORD=postgres
